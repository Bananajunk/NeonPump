{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neonpump",
  "compatibility_date": "2026-07-05",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "bun run build"
  },
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
